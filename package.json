{
  "name": "options-advisor",
  "version": "0.1.0",
  "description": "AI-powered options trading advisor using AWS CDK v2 and TypeScript",
  "license": "MIT",
  "engines": {
    "node": "24",
    "npm": ">=11"
  },
  "bin": {
    "infra": "infrastructure/bin/app.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --project tsconfig.json --noEmit --skipLibCheck",
    "lint": "prettier --check . && eslint . --ext .ts,.js",
    "lint:fix": "prettier --write . && eslint --fix . --ext .ts,.js",
    "test": "jest --maxWorkers=4",
    "test:update": "npm run test -- -u",
    "test:infra": "jest --config=jest.config.infra.js --passWithNoTests",
    "test:acceptance": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.acceptance.js",
    "test:acceptance:pipeline": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.acceptance.js acceptance/pipeline.test.ts",
    "test:acceptance:lambdas": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.acceptance.js --testPathIgnorePatterns pipeline",
    "deploy": "cdk deploy --context stackType=prod --require-approval never",
    "deploy:dev": "cdk deploy --context stackType=dev --require-approval never",
    "diff": "cdk diff --context stackType=prod",
    "diff:dev": "cdk diff --context stackType=dev",
    "analyze": "bash scripts/run-analysis.sh",
    "analyze:dev": "bash scripts/run-analysis.sh --stage dev",
    "analyze:date": "bash scripts/run-analysis.sh --date",
    "seed": "bash scripts/seed-watchlist.sh",
    "seed:dev": "bash scripts/seed-watchlist.sh dev"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1035.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-secrets-manager": "^3.1035.0",
    "@aws-sdk/client-ses": "^3.1035.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.1035.0",
    "@aws-sdk/client-sfn": "^3.1035.0",
    "@aws-sdk/client-sts": "^3.1035.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "aws-cdk": "^2.177.0",
    "aws-cdk-lib": "^2.177.0",
    "aws-sdk-client-mock": "^4.0.0",
    "aws-sdk-client-mock-jest": "^4.0.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.6.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
